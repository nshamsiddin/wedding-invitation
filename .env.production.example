# Production environment template for the wedding invitation server.
#
# HOW TO USE
# ----------
# 1. Copy this file to /opt/invitation/.env on the server:
#      cp .env.production.example /opt/invitation/.env
#
# 2. Fill in every value marked with <FILL_IN> using the generation
#    commands provided in the comments.
#
# 3. Set strict permissions so only the deploy user can read it:
#      chmod 600 /opt/invitation/.env
#
# IMPORTANT: Never commit this file with real values to version control.
# The .gitignore already excludes .env, but double-check before any push.

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
# Absolute path prevents data loss if the working directory changes on restart.
# The directory must exist and be writable by the deploy user before first start.
# Create it with: mkdir -p /opt/invitation/data
DATABASE_PATH=/opt/invitation/data/guests.db

# ── Application URL ────────────────────────────────────────────────────────────
# Public HTTPS URL — used to construct shareable invitation links in the admin
# panel. Must match your actual domain. No trailing slash.
BASE_URL=https://<YOUR_DOMAIN>

# ── Admin credentials ──────────────────────────────────────────────────────────
# Choose a non-obvious username (not "admin").
ADMIN_USERNAME=<FILL_IN>

# ADMIN_PASSWORD must be a bcrypt hash — plain text is rejected at startup.
# Generate a hash (replace 'yourpassword' with your chosen password):
#
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
#
# Cost factor 12 is recommended: ~300 ms per comparison, resistant to GPU cracking.
ADMIN_PASSWORD=<FILL_IN bcrypt hash starting with $2b$12$...>

# ── JWT secret ─────────────────────────────────────────────────────────────────
# Used to sign admin session tokens. Must be a cryptographically random string
# of at least 48 bytes. The server will refuse to start with the example value.
#
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
JWT_SECRET=<FILL_IN 96-character hex string>
