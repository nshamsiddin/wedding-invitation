# ── Admin credentials ──────────────────────────────────────────────────────────
# Username for the admin panel login.
ADMIN_USERNAME=admin

# Password for the admin panel.
# In PRODUCTION this MUST be a bcrypt hash (prefix $2b$). Plain text is rejected
# at startup when NODE_ENV=production.
# Generate a hash: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD=changeme

# ── JWT ────────────────────────────────────────────────────────────────────────
# Secret used to sign admin session tokens. Must be a strong, unique random string
# of at least 32 characters. The server will refuse to start if this is left as
# the example value below.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-in-production

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Use an absolute path in production to avoid
# data loss if the working directory changes (e.g. on container restart).
DATABASE_PATH=./guests.db

# ── Application URL ────────────────────────────────────────────────────────────
# Public base URL of the app — used to construct shareable invitation links
# in the admin panel. Must be set; the server will not start without it.
# In production, use your real domain (e.g. https://wedding.example.com).
BASE_URL=http://localhost:5173
