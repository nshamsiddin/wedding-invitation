{
  "name": "@invitation/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "migrate": "node scripts/migrate.js",
    "db:push": "node scripts/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@invitation/shared": "*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.21.4",
    "supertest": "^7.2.2",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
