{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "./dist",
    "rootDir": "..",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "types": ["node", "bcryptjs", "better-sqlite3", "compression", "cookie-parser", "cors", "express", "jsonwebtoken"],
    "paths": {
      "@invitation/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
